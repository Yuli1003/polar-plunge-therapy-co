---
import Layout from "../layouts/Layout.astro";
import { SITE, wixImg } from "../lib/site";
import { getResearchSummaries } from "../lib/cms";

const research = await getResearchSummaries();
const activeTopic = Astro.url.searchParams.get("topic");
const topics = [...new Set(research.map((r) => r.topic))];
const filtered = activeTopic ? research.filter((r) => r.topic === activeTopic) : research;

const description =
  "An honest library of research summaries on cold exposure, inflammation, and mood — with study types, sample sizes, and effect sizes, including where the evidence is thin.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalScholarlyArticle",
  headline: "What the evidence on cold-exposure therapy actually says",
  description,
  author: { "@type": "MedicalClinic", name: SITE.name },
  about: research.slice(0, 6).map((r) => ({ "@type": "MedicalCondition", name: r.topic })),
};
---

<Layout title="The Evidence" description={description} jsonLd={jsonLd}>
  <header class="mx-auto max-w-[1600px] px-5 pt-16 lg:px-10 lg:pt-24">
    <div class="grid gap-y-8 lg:grid-cols-12 lg:gap-x-8">
      <p class="eyebrow lg:col-span-12">The evidence</p>
      <h1 class="font-display text-[2.5rem] font-normal leading-[1.07] tracking-tight sm:text-6xl lg:col-span-8">
        What the studies actually say —<br /><span class="italic text-ink-soft">including where they are thin.</span>
      </h1>
      <p class="max-w-md self-end text-lg leading-relaxed text-ink-soft lg:col-span-4">
        Moderate evidence for reduced inflammation and short-term mood lift; weaker
        evidence for the bigger claims. We report study type, sample size, and an
        effect size we don't inflate.
      </p>
    </div>
    <img src={wixImg("mistHorizon", 1760, 620)} alt="Pale still water meeting soft fog at a faint horizon" width="1760" height="620" loading="lazy" decoding="async" class="mist-img mt-12 aspect-[16/6] w-full object-cover" />
  </header>

  <section class="mx-auto max-w-[1600px] px-5 py-14 lg:px-10 lg:py-20">
    <!-- topic filters -->
    <nav class="flex flex-wrap items-center gap-x-7 gap-y-2 border-b border-line pb-6" aria-label="Filter by topic">
      <a href="/evidence" class:list={["font-display text-lg transition-colors", !activeTopic ? "text-ink" : "text-ink-faint hover:text-ink"]}>
        {!activeTopic && <span class="mr-1 text-mist" aria-hidden="true">·</span>}All studies
      </a>
      {
        topics.map((t) => (
          <a href={`/evidence?topic=${encodeURIComponent(t)}`} class:list={["font-display text-lg transition-colors", activeTopic === t ? "text-ink" : "text-ink-faint hover:text-ink"]}>
            {activeTopic === t && <span class="mr-1 text-mist" aria-hidden="true">·</span>}{t}
          </a>
        ))
      }
    </nav>

    <!-- readable single-column entries -->
    <ul>
      {
        filtered.map((r) => (
          <li class="border-b border-line py-10 lg:py-12">
            <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
              <h2 class="max-w-3xl font-display text-2xl leading-snug sm:text-[1.75rem]">{r.title}</h2>
              <span class="annot shrink-0">{r.topic} · {r.year}</span>
            </div>
            <p class="mt-3 max-w-3xl font-display text-xl italic leading-snug text-ink-soft">{r.claim}.</p>
            <p class="mt-6 max-w-[64ch] leading-[1.65] text-ink-soft">{r.summary}</p>
            <p class="annot mt-6 flex flex-wrap gap-x-2">
              <span>{r.studyType}</span><span aria-hidden="true">·</span>
              <span>{r.sampleSize}</span><span aria-hidden="true">·</span>
              <span>Effect strength: <span class="text-ink">{r.effectStrength}</span></span>
            </p>
          </li>
        ))
      }
    </ul>

    <div class="pt-10">
      <a href="/protocol" class="cta">The protocol is built on these studies — read it next <span aria-hidden="true">→</span></a>
    </div>
  </section>
</Layout>
