---
import Layout from "../layouts/Layout.astro";
import { SITE, PROTOCOL_WEEKS, wixImg } from "../lib/site";

const description =
  "The full 8-week supervised cold-exposure protocol: week-by-week water temperatures, immersion durations, and what we monitor at each stage. Nothing improvised.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MedicalTherapy",
  name: "8-Week Supervised Cold-Exposure Protocol",
  description,
  howPerformed:
    "A cardiologist-screened, supervisor-monitored cold-immersion program progressing from ~12°C to ~5°C across eight weeks, with written temperatures and durations.",
  medicineSystem: "https://schema.org/WesternConventional",
  relevantSpecialty: "Cardiology",
  provider: { "@type": "MedicalClinic", name: SITE.name },
};

const durations = PROTOCOL_WEEKS.map((w) => parseInt(w.duration.split(":")[0], 10) * 60 + parseInt(w.duration.split(":")[1], 10));

// combined chart geometry — temperature descends, immersion ascends, across 8 weeks
const W = 1000, H = 340, padT = 42, padB = 34;
const plotH = H - padT - padB;
const xs = PROTOCOL_WEEKS.map((_, i) => +(W * ((i + 0.5) / 8)).toFixed(1));
const yT = (v: number) => +(padT + plotH * (1 - (v - 5) / (12 - 5))).toFixed(1);
const yD = (s: number) => +(padT + plotH * (1 - (s - 30) / (240 - 30))).toFixed(1);
const tempPts = PROTOCOL_WEEKS.map((w, i) => ({ x: xs[i], y: yT(w.tempC) }));
const durPts = durations.map((s, i) => ({ x: xs[i], y: yD(s) }));
const poly = (pts: { x: number; y: number }[]) => pts.map((p, i) => `${i ? "L" : "M"}${p.x},${p.y}`).join(" ");

const atmoImg = wixImg("mistVapor", 1600, 700);
---

<Layout title="The 8-Week Protocol" description={description} jsonLd={jsonLd}>
  <header class="mx-auto max-w-[1600px] px-5 pt-16 lg:px-10 lg:pt-24">
    <div class="grid gap-y-8 lg:grid-cols-12 lg:gap-x-8">
      <p class="eyebrow lg:col-span-12">The 8-week protocol</p>
      <h1 class="font-display text-[2.5rem] font-normal leading-[1.07] tracking-tight sm:text-6xl lg:col-span-8">
        Eight weeks, written down to the degree and the second.
      </h1>
      <p class="max-w-md self-end text-lg leading-relaxed text-ink-soft lg:col-span-4">
        The protocol starts around 12&thinsp;°C for short, supervised exposures and
        progresses over eight weeks. Every temperature and duration is written into
        your program — nothing is improvised or pushed past your tolerance.
      </p>
    </div>
  </header>

  <!-- The shape of the program: one chart, two crossing curves -->
  <section class="mx-auto max-w-[1600px] border-t border-line px-5 pt-14 lg:px-10 lg:pt-20">
    <div class="grid gap-y-8 lg:grid-cols-12 lg:gap-x-8">
      <p class="eyebrow lg:col-span-3">The shape of it</p>
      <h2 class="font-display text-2xl leading-snug lg:col-span-9 lg:text-3xl">
        As the water gets colder, you stay in longer. The two curves cross around
        week four — that crossing is the whole program.
      </h2>
    </div>

    <!-- legend -->
    <div class="mt-12 flex flex-wrap gap-x-12 gap-y-4">
      <span class="flex items-center gap-3">
        <span class="h-0.5 w-7" style="background: var(--color-mist)"></span>
        <span class="metric-label">Water temperature</span>
        <span class="font-display tabular-nums">12 → 5 <span class="metric-unit text-ink-faint">°c</span></span>
      </span>
      <span class="flex items-center gap-3">
        <span class="h-0.5 w-7" style="background: var(--color-ink)"></span>
        <span class="metric-label">Max immersion</span>
        <span class="font-display tabular-nums">0:30 → 4:00 <span class="metric-unit text-ink-faint">min</span></span>
      </span>
    </div>

    <!-- chart -->
    <div class="mt-8">
      <svg viewBox={`0 0 ${W} ${H}`} class="w-full" role="img" aria-label="Across eight weeks, water temperature falls from 12 to 5 degrees while maximum immersion rises from 30 seconds to 4 minutes; the two curves cross around week four.">
        {xs.map((x) => <line x1={x} x2={x} y1={padT} y2={H - padB} stroke="var(--color-line)" stroke-width="1" vector-effect="non-scaling-stroke" />)}
        <path d={poly(tempPts)} fill="none" stroke="var(--color-mist)" stroke-width="1.75" vector-effect="non-scaling-stroke" stroke-linejoin="round" />
        <path d={poly(durPts)} fill="none" stroke="var(--color-ink)" stroke-width="1.75" vector-effect="non-scaling-stroke" stroke-linejoin="round" />
        {tempPts.map((p) => <circle cx={p.x} cy={p.y} r="3.4" fill="var(--color-background)" stroke="var(--color-mist)" stroke-width="1.5" vector-effect="non-scaling-stroke" />)}
        {durPts.map((p) => <circle cx={p.x} cy={p.y} r="3.4" fill="var(--color-ink)" />)}
      </svg>
      <div class="mt-3 grid grid-cols-8 border-t border-line pt-3">
        {PROTOCOL_WEEKS.map((w) => <span class="annot text-center">{w.week}</span>)}
      </div>
      <p class="annot mt-2 text-center">Week</p>
    </div>
  </section>

  <!-- Week by week ledger -->
  <section class="mx-auto max-w-[1600px] px-5 py-16 lg:px-10 lg:py-24">
    <div class="grid gap-y-6 lg:grid-cols-12 lg:gap-x-8">
      <p class="eyebrow lg:col-span-3">Week by week</p>
      <div class="lg:col-span-9">
        <div class="grid grid-cols-[2.5rem_5.5rem_1fr] gap-x-4 border-b border-line pb-3 sm:grid-cols-[3rem_7rem_7rem_1fr]">
          <span class="annot">Wk</span>
          <span class="annot">Water</span>
          <span class="annot max-sm:hidden">Immersion</span>
          <span class="annot text-right sm:text-left">Monitored</span>
        </div>
        {
          PROTOCOL_WEEKS.map((w) => (
            <div class="grid grid-cols-[2.5rem_5.5rem_1fr] items-baseline gap-x-4 border-b border-line py-6 transition-colors hover:bg-surface sm:grid-cols-[3rem_7rem_7rem_1fr]">
              <span class="annot pt-3">{w.week}</span>
              <span class="font-display text-3xl tabular-nums sm:text-4xl">{w.tempC}<span class="metric-unit text-base text-ink-faint"> °c</span></span>
              <span class="font-display text-xl tabular-nums max-sm:hidden">{w.duration}<span class="metric-unit text-ink-faint"> min</span></span>
              <span class="self-center text-ink-soft max-sm:col-span-3 max-sm:mt-2 max-sm:text-sm">
                <span class="metric-unit mr-2 hidden text-ink-faint max-sm:inline">{w.duration} min ·</span>{w.monitoring}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Supervision statement -->
  <section class="mx-auto max-w-[1600px] border-t border-line px-5 py-16 lg:px-10 lg:py-24">
    <div class="grid gap-y-6 lg:grid-cols-12 lg:gap-x-8">
      <p class="eyebrow lg:col-span-3">On the deck</p>
      <p class="max-w-3xl font-display text-2xl leading-[1.4] lg:col-span-9 lg:text-[1.9rem]">
        A trained supervisor stays on the deck for every immersion and watches your
        response. We end a session the moment your body says so — the written
        numbers are a ceiling, never a target.
      </p>
    </div>
  </section>

  <!-- Atmosphere -->
  <section class="relative border-y border-line">
    <img src={atmoImg} alt="Cold vapor dissolving into pale air" width="1600" height="700" loading="lazy" decoding="async" class="mist-img h-[46vh] min-h-[300px] w-full object-cover" />
    <div class="absolute inset-0 flex items-center">
      <div class="mx-auto w-full max-w-[1600px] px-5 lg:px-10">
        <h2 class="max-w-lg font-display text-3xl leading-snug sm:text-4xl">The protocol only begins after a clean cardiac screen.</h2>
      </div>
    </div>
  </section>
</Layout>
