---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found" description="The page you're looking for doesn't exist or has been moved.">
  <section class="mx-auto max-w-3xl px-5 py-32 lg:py-44">
    <p class="eyebrow">Error 404</p>
    <h1 class="mt-7 font-display text-5xl font-normal tracking-tight sm:text-6xl">This page isn't on the deck.</h1>
    <p class="mt-7 text-lg text-ink-soft">The page you're looking for doesn't exist or has been moved.</p>
    <div class="mt-10 flex flex-col gap-5 sm:flex-row sm:gap-9">
      <a href="/" class="cta">Back to home <span aria-hidden="true">→</span></a>
      <a href="/intake" class="cta-quiet">Start medical screening</a>
    </div>
  </section>
</Layout>
