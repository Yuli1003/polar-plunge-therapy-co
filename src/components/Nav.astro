---
import { SITE, NAV_LINKS } from "../lib/site";
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== "/" && path.startsWith(href));
---

<header class="sticky top-0 z-40 border-b border-line bg-background/85 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-[1600px] items-center justify-between gap-6 px-5 py-5 lg:px-10" aria-label="Primary">
    <a href="/" class="font-display text-base tracking-[0.32em] text-ink" aria-label={`${SITE.name} — home`}>
      POLAR&nbsp;PLUNGE
    </a>

    <!-- desktop: quiet serif links -->
    <div class="hidden items-center gap-8 lg:flex">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              "font-display text-[1.02rem] transition-colors hover:text-ink",
              isActive(link.href) ? "text-ink" : "text-ink-soft",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {isActive(link.href) && <span class="mr-1 text-mist" aria-hidden="true">·</span>}
            {link.label}
          </a>
        ))
      }
      <a href="/intake" class="cta-quiet font-display text-[1.02rem]">
        Screening <span aria-hidden="true">(→)</span>
      </a>
    </div>

    <!-- mobile: disclosure menu -->
    <details class="group relative lg:hidden">
      <summary class="annot flex cursor-pointer list-none items-center gap-2 text-ink [&::-webkit-details-marker]:hidden">
        Menu <span class="transition-transform group-open:rotate-90" aria-hidden="true">→</span>
      </summary>
      <div class="absolute right-0 top-9 z-50 w-56 border border-line bg-surface p-5">
        <ul class="space-y-3">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a href={link.href} class="font-display text-lg text-ink-soft hover:text-ink">{link.label}</a>
              </li>
            ))
          }
          <li class="border-t border-line pt-3">
            <a href="/intake" class="cta font-display text-base">Start screening <span aria-hidden="true">→</span></a>
          </li>
        </ul>
      </div>
    </details>
  </nav>
</header>
