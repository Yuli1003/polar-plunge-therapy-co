---
import { SITE, NAV_LINKS } from "../lib/site";
const { hideCta = false } = Astro.props;
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-[1600px] px-5 pb-14 pt-20 lg:px-10 lg:pt-28">
    <!-- closing statement -->
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <p class="font-display text-3xl leading-[1.25] sm:text-4xl">
          Screen first.<br />
          Then, maybe, the water.
        </p>
        {!hideCta && <a href="/intake" class="cta mt-8">Start medical screening <span aria-hidden="true">→</span></a>}
      </div>

      <div class="grid grid-cols-2 gap-8 self-end">
        <nav aria-label="Footer">
          <p class="eyebrow mb-4">Pages</p>
          <ul class="space-y-2.5">
            {NAV_LINKS.map((l) => (
              <li><a href={l.href} class="font-display text-ink-soft transition-colors hover:text-ink">{l.label}</a></li>
            ))}
          </ul>
        </nav>
        <div>
          <p class="eyebrow mb-4">Reykjavík</p>
          <address class="space-y-1.5 font-display not-italic text-ink-soft">
            <p>{SITE.country}</p>
            <p class="text-sm leading-relaxed">{SITE.hours}</p>
            <p class="annot pt-3">{SITE.socials.instagram}</p>
            <p class="annot">{SITE.socials.data}</p>
          </address>
        </div>
      </div>
    </div>

    <hr class="rule my-12" />

    <div class="flex flex-col gap-2 text-ink-faint sm:flex-row sm:items-center sm:justify-between">
      <p class="annot">© {SITE.established}–2026 {SITE.name}</p>
      <p class="annot">We screen before we book — and we will say no when we must.</p>
      <p class="annot">
        Powered by <a href="https://www.wix-headless.dev/" target="_blank" rel="noopener" class="underline decoration-line underline-offset-2 transition-colors hover:text-ink">Wix Headless</a>
      </p>
    </div>
  </div>
</footer>
