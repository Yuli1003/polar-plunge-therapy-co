---
/**
 * Signature illustration — concentric contour ripples spreading from an immersion
 * point. Reads at once as still water disturbed at the surface and as a depth /
 * data contour map, tying every page to the clinic's measured-adaptation promise.
 *
 * variant: "ink"  → cornflower lines on paper (light sections)
 *          "dark" → pale-blue lines on deep ink-blue (full-bleed panels)
 */
interface Props {
  class?: string;
  variant?: "ink" | "dark";
  label?: string;
}
const {
  class: className = "",
  variant = "ink",
  label = "Concentric ripples spreading from the immersion point",
} = Astro.props;

const stroke = variant === "dark" ? "var(--color-on-dark)" : "var(--color-primary)";
const center = variant === "dark" ? "#f4f1ea" : "var(--color-primary)";

const cx = 240;
const cy = 252;
// concentric ripples — flattened ellipses for a still-surface perspective
const rings = [26, 52, 82, 116, 154, 196, 242];
---

<svg
  class={className}
  viewBox="0 0 480 480"
  role="img"
  aria-label={label}
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- the immersion line across the surface -->
  <line x1="8" x2="472" y1={cy} y2={cy} stroke={stroke} stroke-opacity="0.35" stroke-width="1.25" />

  {
    rings.map((rx, i) => (
      <ellipse
        cx={cx}
        cy={cy}
        rx={rx}
        ry={rx * 0.34}
        fill="none"
        stroke={stroke}
        stroke-width={i === 0 ? 2 : 1.4}
        stroke-opacity={Math.max(0.16, 0.92 - i * 0.12)}
      />
    ))
  }

  <!-- faint outermost ripple, gently pulsing -->
  <ellipse
    class="ripple-pulse"
    cx={cx}
    cy={cy}
    rx="232"
    ry="79"
    fill="none"
    stroke={stroke}
    stroke-width="1.2"
    stroke-opacity="0.14"
  />

  <!-- the entry point + a single rising drop -->
  <ellipse cx={cx} cy={cy} rx="7" ry="2.6" fill={center} />
  <line x1={cx} x2={cx} y1={cy - 86} y2={cy - 40} stroke={stroke} stroke-opacity="0.45" stroke-width="1.4" />
  <circle cx={cx} cy={cy - 96} r="4.5" fill={center} />
</svg>
